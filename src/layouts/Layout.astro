---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Pro Athlete Grudziądz — Klub Lekkoatletyczny",
  description = "Młodzieżowy Klub Sportowy Pro Athlete Grudziądz. Szkolimy utalentowaną młodzież w lekkiej atletyce — biegi, skoki, rzuty, wieloboje. Dołącz do nas!",
} = Astro.props;

const navLinks = [
  { label: "O klubie", href: "#about" },
  { label: "Osiągnięcia", href: "#achievements" },
  { label: "Aktualności", href: "#news" },
  { label: "Kontakt", href: "#contact" },
];
---

<!doctype html>
<html lang="pl" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,700;0,800;0,900;1,900&family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-brand-bg text-brand-text font-body min-h-screen overflow-x-hidden antialiased selection:bg-brand-green selection:text-brand-bg">
    <!-- ─── NAVBAR ─── -->
    <header
      id="navbar"
      class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
    >
      <nav class="flex items-center justify-between px-6 md:px-8 py-4 max-w-7xl mx-auto">
        <a href="#" class="flex items-center gap-3 no-underline">
          <img
            src="/images/logo.jpg"
            alt="Logo Pro Athlete Grudziądz"
            class="h-9 w-9 rounded object-cover"
          />
          <span class="font-heading font-black text-xl text-white italic tracking-tighter">
            PRO ATHLETE
          </span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-8">
          {navLinks.map((l) => (
            <a href={l.href} class="nav-link">{l.label}</a>
          ))}
          <a href="#contact" class="bg-brand-green text-brand-bg px-6 py-2 font-body font-bold uppercase tracking-widest text-xs no-underline hover:bg-white transition-all duration-300 active:scale-90">Dołącz do nas</a>
        </div>

        <!-- Hamburger -->
        <button
          id="menu-toggle"
          class="md:hidden flex flex-col gap-[5px] p-2 bg-transparent border-none cursor-pointer"
          aria-label="Otwórz menu"
        >
          <span class="block w-6 h-0.5 bg-brand-green transition-all"></span>
          <span class="block w-6 h-0.5 bg-brand-green transition-all"></span>
          <span class="block w-6 h-0.5 bg-brand-green transition-all"></span>
        </button>
      </nav>
    </header>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="fixed inset-0 z-[999] flex flex-col items-center justify-center gap-8 bg-brand-bg/[0.97] hidden"
    >
      {navLinks.map((l) => (
        <a
          href={l.href}
          class="mobile-nav-link text-brand-text no-underline font-heading text-3xl font-black uppercase tracking-[3px] hover:text-brand-green transition-colors"
        >{l.label}</a>
      ))}
      <button
        id="menu-close"
        class="absolute top-6 right-6 bg-transparent border-none text-brand-green text-3xl cursor-pointer"
        aria-label="Zamknij menu"
      >&#10005;</button>
    </div>

    <slot />

    <!-- ─── FOOTER ─── -->
    <footer class="bg-brand-bg w-full py-12 px-6 border-t border-white/5">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">
          <div class="flex flex-col items-center md:items-start gap-2">
            <div class="font-heading font-black italic text-lg text-brand-green uppercase tracking-tighter">
              PRO ATHLETE GRUDZIĄDZ
            </div>
            <p class="text-brand-muted text-sm">
              Klub Sportowy · Sekcja Lekkiej Atletyki · Grudziądz
            </p>
          </div>
          <div class="flex flex-wrap justify-center gap-6">
            <a class="text-sm font-medium tracking-wide text-brand-muted hover:text-brand-green transition-all no-underline" href="#">Polityka Prywatności</a>
            <a class="text-sm font-medium tracking-wide text-brand-muted hover:text-brand-green transition-all no-underline" href="#">Regulamin Klubu</a>
            <a class="text-sm font-medium tracking-wide text-brand-muted hover:text-brand-green transition-all no-underline" href="#">PZLA</a>
          </div>
          <div class="flex gap-4">
            <a
              class="w-10 h-10 flex items-center justify-center bg-brand-mid text-brand-green hover:bg-brand-green hover:text-brand-bg transition-all no-underline"
              href="https://www.facebook.com/Proathletegrudziadz"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
            >
              <span class="material-symbols-outlined">share</span>
            </a>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-white/5 text-center">
          <p class="text-brand-muted text-sm">
            &copy; {new Date().getFullYear()} Pro Athlete Grudziądz. Wszelkie prawa zastrzeżone.
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Navbar scroll effect
      const navbar = document.getElementById("navbar");
      window.addEventListener("scroll", () => {
        if (!navbar) return;
        if (window.scrollY > 50) {
          navbar.style.background = "rgba(10, 10, 10, 0.95)";
          navbar.style.backdropFilter = "blur(12px)";
          navbar.style.borderBottom = "1px solid rgba(107, 240, 64, 0.1)";
          navbar.style.boxShadow = "0 4px 30px rgba(107, 240, 64, 0.05)";
        } else {
          navbar.style.background = "transparent";
          navbar.style.backdropFilter = "none";
          navbar.style.borderBottom = "none";
          navbar.style.boxShadow = "none";
        }
      }, { passive: true });

      // Mobile menu
      const menuToggle = document.getElementById("menu-toggle");
      const menuClose = document.getElementById("menu-close");
      const mobileMenu = document.getElementById("mobile-menu");

      menuToggle?.addEventListener("click", () => {
        mobileMenu?.classList.remove("hidden");
      });
      menuClose?.addEventListener("click", () => {
        mobileMenu?.classList.add("hidden");
      });
      mobileMenu?.querySelectorAll(".mobile-nav-link").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu?.classList.add("hidden");
        });
      });
    </script>
  </body>
</html>
