---
interface Props {
  label: string;
  title: string;
}

const { label, title } = Astro.props;
---

<div class="mb-12 text-center">
  <div class="font-body text-xs font-semibold text-brand-green uppercase tracking-[4px] mb-3">
    {label}
  </div>
  <h2 class="font-heading text-[clamp(28px,5vw,48px)] font-bold text-brand-text uppercase leading-tight m-0">
    {title}
  </h2>
  <div class="w-15 h-[3px] bg-brand-green mx-auto mt-4 rounded-sm"></div>
</div>
