---
import Layout from "../layouts/Layout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import AchievementCard from "../components/AchievementCard.astro";
import "../styles/global.css";

const disciplines = [
  "Biegi sprinterskie",
  "Biegi średniodystansowe",
  "Skoki",
  "Rzuty",
  "Wieloboje",
];

const stats = [
  { value: "20+", label: "Zawodników" },
  { value: "2024", label: "Rok założenia" },
  { value: "15+", label: "Medali" },
  { value: "4", label: "Kategorie wiekowe" },
];
---

<Layout>
  <!-- ─── HERO ─── -->
  <section class="min-h-screen flex items-center justify-center relative overflow-hidden px-6 pt-30 pb-20">
    <!-- Track lines background -->
    <div class="absolute inset-0 opacity-[0.06]">
      {Array.from({ length: 8 }).map((_, i) => (
        <div
          class="absolute left-0 right-0 h-px bg-brand-green"
          style={`top: ${12 + i * 11}%`}
        />
      ))}
    </div>

    <!-- Glowing orb -->
    <div
      class="absolute top-[20%] right-[10%] w-[400px] h-[400px] rounded-full blur-[80px] animate-pulse-glow"
      style="background: radial-gradient(circle, rgba(107, 240, 64, 0.3) 0%, transparent 70%);"
    ></div>

    <!-- Running track line animation -->
    <div class="absolute bottom-[15%] left-0 right-0 h-0.5 overflow-hidden">
      <div
        class="w-[30%] h-full animate-track-line"
        style="background: linear-gradient(90deg, transparent, #6BF040, transparent);"
      ></div>
    </div>

    <!-- Hero content -->
    <div class="text-center relative z-10 max-w-[800px] animate-slide-up">
      <div class="animate-float mb-8">
        <img
          src="/images/logo.jpg"
          alt="Logo Pro Athlete Grudziądz"
          class="w-40 h-40 mx-auto rounded-xl object-cover shadow-lg shadow-brand-green/20"
        />
      </div>

      <div class="font-body text-xs font-semibold text-brand-green uppercase tracking-[6px] mb-4 animate-slide-up animate-delay-200">
        Klub Lekkoatletyczny · Grudziądz
      </div>

      <h1 class="font-heading text-[clamp(36px,8vw,72px)] font-bold leading-[1.05] uppercase mb-6 animate-slide-up animate-delay-300">
        Kształtujemy{" "}
        <span class="text-brand-green" style="text-shadow: 0 0 40px rgba(107, 240, 64, 0.3);">
          Mistrzów
        </span>
        <br />Jutra
      </h1>

      <p class="text-[clamp(15px,2vw,18px)] text-brand-muted leading-relaxed max-w-[560px] mx-auto mb-10 animate-slide-up animate-delay-400">
        Szkolimy utalentowaną młodzież z Grudziądza. Od kategorii U12 po seniorów —
        medale mistrzostw Polski, pasja i profesjonalizm na każdym treningu.
      </p>

      <div class="flex gap-4 justify-center flex-wrap animate-slide-up animate-delay-500">
        <a href="#contact" class="cta-btn">Dołącz do klubu &rarr;</a>
        <a href="#achievements" class="cta-btn-outline">Nasze osiągnięcia</a>
      </div>
    </div>
  </section>

  <!-- ─── STATS BAR ─── -->
  <section class="border-y border-brand-green/10 bg-brand-dark">
    <div class="max-w-[960px] mx-auto grid grid-cols-2 md:grid-cols-4">
      {stats.map((s) => (
        <div class="stat-card">
          <div class="font-heading text-[clamp(28px,4vw,42px)] font-bold text-brand-green leading-none counter-value" data-target={s.value}>
            {s.value}
          </div>
          <div class="font-body text-xs text-brand-muted uppercase tracking-widest mt-2">
            {s.label}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── ABOUT ─── -->
  <section id="about" class="py-24 px-6 max-w-[960px] mx-auto">
    <SectionTitle label="O nas" title="Młody klub, wielkie ambicje" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 animate-slide-up">
      <div>
        <p class="text-base leading-relaxed text-brand-muted mb-5">
          <strong class="text-brand-text">Pro Athlete Grudziądz</strong> to młode stowarzyszenie
          sportowe działające jako klub lekkoatletyczny. Powstaliśmy 17 marca 2024 roku z pasji do lekkiej
          atletyki i wiary w potencjał grudziądzkiej młodzieży.
        </p>
        <p class="text-base leading-relaxed text-brand-muted">
          Nasi zawodnicy regularnie zdobywają medale mistrzostw wojewódzkich, międzywojewódzkich
          i odnoszą sukcesy na mistrzostwach Polski. Trenujemy systematycznie w kategoriach
          od U12 po seniorów.
        </p>
      </div>

      <div class="bg-brand-mid rounded-xl p-8 border border-brand-green/10">
        <div class="font-heading text-xl font-semibold text-brand-green uppercase mb-5">
          Szkolimy w dyscyplinach
        </div>
        {disciplines.map((d, i) => (
          <div class:list={[
            "flex items-center gap-3 py-2.5",
            i < disciplines.length - 1 && "border-b border-white/5"
          ]}>
            <div
              class="w-2 h-2 rounded-full bg-brand-green shrink-0"
              style="box-shadow: 0 0 8px rgba(107, 240, 64, 0.3);"
            ></div>
            <span class="text-[15px] text-brand-text">{d}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── ACHIEVEMENTS ─── -->
  <section id="achievements" class="py-24 px-6" style="background: linear-gradient(180deg, #0A0A0A, #111111 50%, #0A0A0A);">
    <div class="max-w-[960px] mx-auto">
      <SectionTitle label="Sukcesy" title="Medaliści i wyróżnienia" />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <AchievementCard
          icon="🥈"
          name="Andrzej Rogiewicz"
          result="2. miejsce Mistrzostw Polski"
          competition="Lekkoatletyka · Stypendysta miasta Grudziądz"
          delay="0.1s"
        />
        <AchievementCard
          icon="🏅"
          name="Krzysztof Mira"
          result="Nagrodzony Działacz Sportowy"
          competition="Gala Sportu · Grudziądz 2024"
          delay="0.2s"
        />
        <AchievementCard
          icon="🏆"
          name="Sekcja Pro Athlete"
          result="Medale Mistrzostw Wojewódzkich"
          competition="Kategorie U12 – U20 · Sezon 2024/2025"
          delay="0.3s"
        />
      </div>

      <div class="text-center mt-12 animate-slide-up animate-delay-500">
        <p class="text-sm text-brand-muted italic max-w-[500px] mx-auto">
          Czołowe lokaty na Mistrzostwach Polski w kat. U18 · Medale międzywojewódzkie · Systematyczny rozwój zawodników
        </p>
      </div>
    </div>
  </section>

  <!-- ─── FACEBOOK / NEWS ─── -->
  <section id="news" class="py-24 px-6" style="background: linear-gradient(180deg, #0A0A0A 0%, #111111 50%, #0A0A0A 100%);">
    <div class="max-w-[960px] mx-auto">
      <SectionTitle label="Aktualności" title="Śledź nas na Facebooku" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <!-- FB Page Plugin embed -->
        <div class="bg-brand-mid rounded-xl overflow-hidden border border-brand-green/10 min-h-[500px] flex flex-col items-center justify-center p-6">
          <div class="w-full rounded-lg overflow-hidden bg-brand-mid min-h-[460px] flex flex-col items-center">
            <!-- FB header -->
            <div class="w-full p-5 flex items-center gap-3" style="background: linear-gradient(135deg, #1877F2, #0D5BD9);">
              <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-xl font-bold text-[#1877F2]">f</div>
              <div>
                <div class="font-bold text-[15px] text-white">Pro Athlete Grudziądz</div>
                <div class="text-xs text-white/70">@Proathletegrudziadz</div>
              </div>
            </div>
            <!-- FB content placeholder -->
            <div class="p-5 w-full">
              <div id="fb-root"></div>
              <div
                class="fb-page"
                data-href="https://www.facebook.com/Proathletegrudziadz"
                data-tabs="timeline"
                data-width=""
                data-height="400"
                data-small-header="true"
                data-adapt-container-width="true"
                data-hide-cover="false"
                data-show-facepile="false"
              >
                <blockquote cite="https://www.facebook.com/Proathletegrudziadz" class="fb-xfbml-parse-ignore">
                  <a href="https://www.facebook.com/Proathletegrudziadz">Pro Athlete Grudziądz</a>
                </blockquote>
              </div>
            </div>
          </div>
        </div>

        <!-- Side info -->
        <div class="flex flex-col gap-5">
          <div class="bg-brand-mid rounded-xl p-7 border border-brand-green/10">
            <div class="font-heading text-lg font-semibold text-brand-green uppercase mb-4">Dlaczego Facebook?</div>
            <p class="text-sm leading-relaxed text-brand-muted">
              Nasz fan-page to serce komunikacji klubu. Zdjęcia z zawodów,
              relacje z treningów, osiągnięcia zawodników — wszystko na bieżąco.
              Widget automatycznie wyświetla najnowsze posty.
            </p>
          </div>

          <a
            href="https://www.facebook.com/Proathletegrudziadz"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 rounded-xl p-5 no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-[#1877F2]/30"
            style="background: linear-gradient(135deg, #1877F2, #0D5BD9);"
          >
            <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center text-2xl text-white font-bold">f</div>
            <div>
              <div class="font-bold text-base text-white">Odwiedź nasz fan-page</div>
              <div class="text-[13px] text-white/70">Zdjęcia · Filmy · Relacje na żywo</div>
            </div>
            <div class="ml-auto text-xl text-white">&rarr;</div>
          </a>

          <div class="bg-brand-mid rounded-xl p-7 border border-brand-green/10">
            <div class="font-heading text-lg font-semibold text-brand-green uppercase mb-4">Wesprzyj klub</div>
            <p class="text-sm leading-relaxed text-brand-muted mb-4">
              Pomagamy utalentowanej młodzieży rozwijać sportowe talenty.
              Każda pomoc się liczy — sprzęt, transport na zawody, obozy.
            </p>
            <a
              href="https://zrzutka.pl/en/n2eu4f"
              target="_blank"
              rel="noopener noreferrer"
              class="cta-btn-outline !text-[13px] !py-2.5 !px-5 w-full justify-center"
            >
              Zrzutka.pl — Wesprzyj nas
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CONTACT / CTA ─── -->
  <section id="contact" class="py-24 px-6 relative">
    <!-- Glow -->
    <div
      class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full blur-[100px] opacity-15"
      style="background: radial-gradient(circle, rgba(107, 240, 64, 0.3) 0%, transparent 70%);"
    ></div>

    <div class="max-w-[700px] mx-auto text-center relative z-10">
      <SectionTitle label="Dołącz" title="Rozpocznij swoją przygodę z lekkoatletyką" />

      <p class="text-base leading-relaxed text-brand-muted mb-10">
        Zapraszamy dzieci i młodzież na treningi lekkoatletyczne.
        Profesjonalne szkolenie, przyjazna atmosfera i droga do sportowych sukcesów.
        Skontaktuj się z nami!
      </p>

      <div class="bg-brand-mid rounded-2xl p-10 border border-brand-green/15 mb-8">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
          <div>
            <div class="text-2xl mb-2">📍</div>
            <div class="font-heading text-sm font-semibold text-brand-green uppercase tracking-wide mb-1">Lokalizacja</div>
            <div class="text-sm text-brand-muted">Grudziądz<br />woj. kujawsko-pomorskie</div>
          </div>
          <div>
            <div class="text-2xl mb-2">👤</div>
            <div class="font-heading text-sm font-semibold text-brand-green uppercase tracking-wide mb-1">Kontakt</div>
            <div class="text-sm text-brand-muted">Krzysztof Mira<br />Prezes Klubu</div>
          </div>
          <div>
            <div class="text-2xl mb-2">🏃</div>
            <div class="font-heading text-sm font-semibold text-brand-green uppercase tracking-wide mb-1">Kategorie</div>
            <div class="text-sm text-brand-muted">U12 · U16 · U18<br />U20 · Seniorzy</div>
          </div>
        </div>
      </div>

      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="https://www.facebook.com/Proathletegrudziadz"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-btn"
        >
          Napisz do nas na Facebooku &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Facebook SDK -->
  <script is:inline>
    // Facebook Page Plugin SDK (async)
    (function(d, s, id) {
      var js, fjs = d.getElementsByTagName(s)[0];
      if (d.getElementById(id)) return;
      js = d.createElement(s); js.id = id;
      js.src = "https://connect.facebook.net/pl_PL/sdk.js#xfbml=1&version=v21.0";
      fjs.parentNode.insertBefore(js, fjs);
    }(document, 'script', 'facebook-jssdk'));

    // Animated counters with IntersectionObserver
    document.addEventListener("DOMContentLoaded", () => {
      const counters = document.querySelectorAll(".counter-value");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target;
            const raw = el.dataset.target;
            const num = parseInt(raw);
            if (isNaN(num)) return;
            const suffix = raw.replace(String(num), "");
            const duration = 2000;
            const startTime = Date.now();
            const tick = () => {
              const elapsed = Date.now() - startTime;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.floor(eased * num) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            };
            tick();
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.3 });

      counters.forEach((c) => observer.observe(c));
    });
  </script>
</Layout>
